generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RoomStatus {
  available
  occupied
  cleaning
}

enum ReservationStatus {
  confirmed
  checked_in
  checked_out
  cancelled
}

enum StaffRole {
  admin
  manager
  front_desk
  housekeeping
}

enum Shift {
  morning
  evening
  night
}

enum TaskType {
  clean
  inspect
  restock
  repair
}

enum TaskStatus {
  pending
  in_progress
  done
}

enum Priority {
  low
  normal
  urgent
}

enum InvoiceStatus {
  draft
  issued
  paid
  void
}

enum PaymentMethod {
  cash
  card
  bank_transfer
  upi
}

// ─── Models ───────────────────────────────────────────────────────────────────

model RoomType {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  basePrice    Decimal @map("base_price")
  maxOccupancy Int     @map("max_occupancy")
  amenities    Json?
  rooms        Room[]

  @@map("room_types")
}

model Room {
  id           Int                @id @default(autoincrement())
  roomNumber   String             @unique @map("room_number")
  floor        Int
  roomTypeId   Int                @map("room_type_id")
  status       RoomStatus         @default(available)
  roomType     RoomType           @relation(fields: [roomTypeId], references: [id])
  reservations Reservation[]
  tasks        HousekeepingTask[]

  @@map("rooms")
}

model Guest {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  phone         String?
  idNumber      String?       @map("id_number")
  loyaltyPoints Int           @default(0) @map("loyalty_points")
  preferences   Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  reservations  Reservation[]

  @@map("guests")
}

model Staff {
  id       Int                @id @default(autoincrement())
  name     String
  email    String             @unique
  password String
  role     StaffRole
  shift    Shift
  tasks    HousekeepingTask[]

  @@map("staff")
}

model Reservation {
  id        Int               @id @default(autoincrement())
  guestId   Int               @map("guest_id")
  roomId    Int               @map("room_id")
  checkIn   DateTime          @map("check_in") @db.Date
  checkOut  DateTime          @map("check_out") @db.Date
  adults    Int               @default(1)
  children  Int               @default(0)
  status    ReservationStatus @default(confirmed)
  notes     String?
  createdAt DateTime          @default(now()) @map("created_at")
  guest     Guest             @relation(fields: [guestId], references: [id])
  room      Room              @relation(fields: [roomId], references: [id])
  invoices  Invoice[]

  @@map("reservations")
}

model HousekeepingTask {
  id          Int        @id @default(autoincrement())
  roomId      Int        @map("room_id")
  assignedTo  Int?       @map("assigned_to")
  type        TaskType
  status      TaskStatus @default(pending)
  priority    Priority   @default(normal)
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  completedAt DateTime?  @map("completed_at")
  room        Room       @relation(fields: [roomId], references: [id])
  staff       Staff?     @relation(fields: [assignedTo], references: [id])

  @@map("housekeeping_tasks")
}

model Invoice {
  id            Int           @id @default(autoincrement())
  reservationId Int           @map("reservation_id")
  subtotal      Decimal
  tax           Decimal
  discount      Decimal       @default(0)
  total         Decimal
  status        InvoiceStatus @default(draft)
  issuedAt      DateTime?     @map("issued_at")
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  payments      Payment[]

  @@map("invoices")
}

model Payment {
  id        Int           @id @default(autoincrement())
  invoiceId Int           @map("invoice_id")
  amount    Decimal
  method    PaymentMethod
  paidAt    DateTime      @default(now()) @map("paid_at")
  invoice   Invoice       @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}
