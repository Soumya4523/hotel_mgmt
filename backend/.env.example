# Session Pooler URL — for runtime queries (from Supabase → Settings → Database → Session mode)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Direct connection URL — for Prisma migrations only (from Supabase → Settings → Database → Direct connection)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"

PORT=4000
